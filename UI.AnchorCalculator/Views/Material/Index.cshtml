@model UI.AnchorCalculator.ViewModels.MaterialsAndWorkPriceViewModel
@{ ViewData["Title"] = "Material"; }

<div class="row" style="max-width: 1400px">
	<div class="col-sm-12 col-md-12">
		<table class="table">
			<thead>
				<tr>
					<th scope="col">#</th>
					<th scope="col">Наим-ие</th>
					<th scope="col">Размер (мм)</th>
					<th scope="col">Тип профиля</th>
					<th scope="col">Цена за метр (сом)</th>
					<th scope="col">Время накатки резьбы (ч)</th>
					<th scope="col">Время нарезки резьбы (ч)</th>
					<th scope="col">Время лентопила (ч)</th>
					<th scope="col">Полотно лентопила (шт)</th>
					<th scope="col">Плашка (шт)</th>
					<th scope="col">Резец (шт)</th>
					<th scope="col">Дата обнов-я</th>
				</tr>
			</thead>

			@if (@Model.Materials.Count != 0)
			{
				<tbody>
					@foreach (var item in Model.Materials)
					{
						<tr id="@item.Id">
							<th scope="row">@item.Id</th>
							<td>@item.Name</td>
							<td>@(String.Format("{0} {1}", "Ø", item.Size))</td>
							<td>@item.Type.ToString()</td>
							<td>@item.PricePerMeter</td>
							<td>@item.ThreadRollingHours</td>
							<td>@item.ThreadCuttingHours</td>
							<td>@item.BandSawHours</td>
							<td>@item.BandSawBladeCount</td>
							<td>@item.PlashkaCount</td>
							<td>@item.CutterCount</td>
							<td>@item.DateUpdate.ToLocalTime()</td>
							<td>
								<p class="btn-group-vertical">
									<a class="btn btn-dark btn-sm" asp-controller="Material" asp-action="Edit" role="button" asp-route-id="@item.Id">Редактировать</a>
									<button type="button" class="btn btn-danger btn-sm" data-bs-toggle="modal" data-bs-target="#exampleModal" onclick="setIdForButton('@item.Id')">Удалить</button>
								</p>
							</td>
						</tr>
					}
				</tbody>
			}
		</table>

		<a class="btn btn-dark mb-3" asp-controller="Material" asp-action="Add" role="button">Добавить материал</a>
	</div>

	<div class="col-sm-0 col-md-0">
		<div class="card">
			<div class="card-body">
				<h5 class="card-title">Стоимость работ и наценка</h5>

				<form id="WorkPriceForm">
					<div class="row mb-3">
						<label for="ExchangeDollar" class="col-sm-9 col-form-label ml-0 pl-0">Курс доллара (сом/$):</label>
						<div class="col-sm-3 mb-1">
							<input asp-for="WorkPrice.ExchangeDollar" type="text" class="form-control" id="ExchangeDollar" value="@Model.WorkPrice.ExchangeDollar">
						</div>

						<label for="PnrRollingThreadDollars" class="col-sm-9 col-form-label ml-0 pl-0">ПНР накатки резьбы ($)</label>
						<div class="col-sm-3 mb-1">
							<input asp-for="WorkPrice.PnrRollingThreadDollars" type="text" class="form-control" id="PnrRollingThreadDollars" value="@Model.WorkPrice.PnrRollingThreadDollars">
						</div>

						<label for="PnrBendingAnchorDollars" class="col-sm-9 col-form-label ml-0 pl-0">ПНР гибки анкеров ($)</label>
						<div class="col-sm-3 mb-1">
							<input asp-for="WorkPrice.PnrBendingAnchorDollars" type="text" class="form-control" id="PnrBendingAnchorDollars" value="@Model.WorkPrice.PnrBendingAnchorDollars">
						</div>

						<label for="PnrBandSawDollars" class="col-sm-9 col-form-label ml-0 pl-0">ПНР резки лентопила ($)</label>
						<div class="col-sm-3 mb-1">
							<input asp-for="WorkPrice.PnrBandSawDollars" type="text" class="form-control" id="PnrBandSawDollars" value="@Model.WorkPrice.PnrBandSawDollars">
						</div>

						<label for="PnrMetalworkingAreaDollars" class="col-sm-9 col-form-label ml-0 pl-0">ПНР слесарного участка ($)</label>
						<div class="col-sm-3 mb-1">
							<input asp-for="WorkPrice.PnrMetalworkingAreaDollars" type="text" class="form-control" id="PnrMetalworkingAreaDollars" value="@Model.WorkPrice.PnrMetalworkingAreaDollars">
						</div>

						<label for="EffectiveLengthMillimeters" class="col-sm-9 col-form-label ml-0 pl-0">Расчетная длина (мм)</label>
						<div class="col-sm-3 mb-1">
							<input asp-for="WorkPrice.EffectiveLengthMillimeters" type="text" class="form-control" id="EffectiveLengthMillimeters" value="@Model.WorkPrice.EffectiveLengthMillimeters" readonly>
						</div>

						<label for="BandSawPriceDollars" class="col-sm-9 col-form-label ml-0 pl-0">Цена лентопила ($)</label>
						<div class="col-sm-3 mb-1">
							<input asp-for="WorkPrice.BandSawPriceDollars" type="text" class="form-control" id="BandSawPriceDollars" value="@Model.WorkPrice.BandSawPriceDollars">
						</div>

						<label for="PlashkaPriceDollars" class="col-sm-9 col-form-label ml-0 pl-0">Цена плашки ($)</label>
						<div class="col-sm-3 mb-1">
							<input asp-for="WorkPrice.PlashkaPriceDollars" type="text" class="form-control" id="PlashkaPriceDollars" value="@Model.WorkPrice.PlashkaPriceDollars">
						</div>

						<label for="CutterPriceDollars" class="col-sm-9 col-form-label ml-0 pl-0">Цена резца ($)</label>
						<div class="col-sm-3 mb-1">
							<input asp-for="WorkPrice.CutterPriceDollars" type="text" class="form-control" id="CutterPriceDollars" value="@Model.WorkPrice.CutterPriceDollars">
						</div>

						<label for="ThreadRollingSettingHours" class="col-sm-9 col-form-label ml-0 pl-0">Время настройки резьбонакатного станка (ч)</label>
						<div class="col-sm-3 mb-1">
							<input asp-for="WorkPrice.ThreadRollingSettingHours" type="text" class="form-control" id="ThreadRollingSettingHours" value="@Model.WorkPrice.ThreadRollingSettingHours">
						</div>

						<label for="BendHours" class="col-sm-9 col-form-label ml-0 pl-0">Время гиба (ч)</label>
						<div class="col-sm-3 mb-1">
							<input asp-for="WorkPrice.BendHours" type="text" class="form-control" id="BendHours" value="@Model.WorkPrice.BendHours">
						</div>

						<label for="BendSettingHours" class="col-sm-9 col-form-label ml-0 pl-0">Время настройки гибочного станка (ч)</label>
						<div class="col-sm-3 mb-1">
							<input asp-for="WorkPrice.BendSettingHours" type="text" class="form-control" id="BendSettingHours" value="@Model.WorkPrice.BendSettingHours">
						</div>

						<label for="MarkupPercent" class="col-sm-9 col-form-label ml-0 pl-0">Наценка (%)</label>
						<div class="col-sm-3 mb-1">
							<input asp-for="MarkupPercent" type="text" class="form-control" id="MarkupPercent" value="@Model.MarkupPercent">
						</div>

						<label for="AdditionalMarkupPercent_DiameterMoreThan30" class="col-sm-9 col-form-label ml-0 pl-0">Дополнительная наценка для толщины &gt; М30 (%)</label>
						<div class="col-sm-3 mb-1">
							<input asp-for="AdditionalMarkupPercent_DiameterMoreThan30" type="text" class="form-control" id="AdditionalMarkupPercent_DiameterMoreThan30" value="@Model.AdditionalMarkupPercent_DiameterMoreThan30">
						</div>
					</div>

					<button id="liveToastBtn" type="submit" class="btn btn-dark mt-2">Изменить</button>
				</form>
			</div>
		</div>
	</div>
</div>

<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">
	<div id="liveToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
		<div class="toast-header">
			<strong class="me-auto">Калькулятор анкеров</strong>
			<small>Только что</small>
			<button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
		</div>

		<div class="toast-body">
			Стоимость работ успешно изменена!
		</div>
	</div>
</div>

<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">
	<div id="liveToastUnLucky" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
		<div class="toast-header">
			<strong class="me-auto">Калькулятор анкеров</strong>
			<small>Только что</small>
			<button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
		</div>

		<div class="toast-body">
			Стоимость работ не изменена! Все поля должны быть заполнены
		</div>
	</div>
</div>

<div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
	<div class="modal-dialog">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title" id="exampleModalLabel">Удаление материала</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
			</div>

			<div id="modal_body" class="modal-body">
				Вы действительно хотите удалить?
			</div>

			<div class="modal-footer">
				<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Нет</button>
				<button id="btnDelCard" type="button" class="btn btn-danger">Да</button>
			</div>
		</div>
	</div>
</div>

<script>
	let materialLine;

	function setIdForButton(id)
	{
		console.log(id);
		materialLine = document.getElementById(id);

		var nameMaterial = materialLine.getElementsByTagName('td')[0].textContent;
		var sizeMaterial = materialLine.getElementsByTagName('td')[1].textContent;
		var btnDelCard = document.getElementById("btnDelCard");
		var modal_body = document.getElementById("modal_body");

		modal_body.innerHTML = 'Вы действительно хотите удалить материал ' + nameMaterial + ' '+sizeMaterial+' ?';
		btnDelCard.onclick = () => deleteMaterial(id);
	}

	function deleteMaterial(id)
	{
		event.preventDefault();
		$.ajax(
		{
			url: '@Url.Action("Delete","Material")',
			type: 'POST',
			data: { 'id': id },
			success: function (response)
			{
				if (response.success)
					materialLine.remove();
			}
		});
	}

	document.addEventListener("DOMContentLoaded", function (event)
	{
		$("#ExchangeDollar").inputmask(
		{
			alias: 'decimal',
			allowMinus: false,
			digits: 4,
			max: 9999.9999
		});

		$("#PnrRollingThreadDollarsDollars").inputmask(
		{
			alias: 'decimal',
			allowMinus: false,
			digits: 4,
			max: 9999.9999
		});

		$("#PnrBendingAnchorDollars").inputmask(
		{
			alias: 'decimal',
			allowMinus: false,
			digits: 4,
			max: 9999.9999
		});

		$("#PnrBandSawDollars").inputmask(
		{
			alias: 'decimal',
			allowMinus: false,
			digits: 4,
			max: 9999.9999
		});

		$("#PnrMetalworkingAreaDollars").inputmask(
		{
			alias: 'decimal',
			allowMinus: false,
			digits: 4,
			max: 9999.9999
		});

		$("#PlashkaPriceDollars").inputmask(
		{
			alias: 'decimal',
			allowMinus: false,
			digits: 4,
			max: 9999.9999
		});

		$("#CutterPriceDollars").inputmask(
		{
			alias: 'decimal',
			allowMinus: false,
			digits: 4,
			max: 9999.9999
		});

		$("#BandSawPriceDollars").inputmask(
		{
			alias: 'decimal',
			allowMinus: false,
			digits: 4,
			max: 9999.9999
		});

		$("#ThreadRollingSettingHours").inputmask(
		{
			alias: 'decimal',
			allowMinus: false,
			digits: 4,
			max: 9999.9999
		});

		$("#BendHours").inputmask(
		{
			alias: 'decimal',
			allowMinus: false,
			digits: 4,
			max: 9999.9999
		});

		$("#BendSettingHours").inputmask(
		{
			alias: 'decimal',
			allowMinus: false,
			digits: 4,
			max: 9999.9999
		});

		$("#EffectiveLengthMillimeters").inputmask(
		{
			alias: 'numeric',
			allowMinus: false,
			digits: 0,
			max: 999
		});

		$("#MarkupPercent").inputmask(
		{
			alias: 'numeric',
			allowMinus: false,
			digits: 0,
			max: 999
		});

		$("#AdditionalMarkupPercent_DiameterMoreThan30").inputmask(
		{
			alias: 'numeric',
			allowMinus: false,
			digits: 0,
			max: 999
		});
	});

	var workPriceForm = document.getElementById("WorkPriceForm");
	workPriceForm.addEventListener("submit", function formSubmit(event)
	{
		event.preventDefault();

		let inputMarkupPercent = document.getElementById("MarkupPercent");
		let inputAdditionalMarkupPercent_DiameterMoreThan30 = document.getElementById("AdditionalMarkupPercent_DiameterMoreThan30");

		if (inputMarkupPercent.value.trim() === "")
			inputMarkupPercent.value = 0;

		if (inputAdditionalMarkupPercent_DiameterMoreThan30.value.trim() === "")
			inputAdditionalMarkupPercent_DiameterMoreThan30.value = 0;

		var formData = new FormData(workPriceForm);
		$.ajax(
		{
			url: '@Url.Action("EditWorkPrice", "Material")',
			type: 'POST',
			contentType: false,
			processData: false,
			data: formData,
			success: function (response)
			{
				var toast;
				if (response.success)
				{
					var toastTrigger = document.getElementById('liveToastBtn');
					var toastLiveExample = document.getElementById('liveToast');
					toast = new bootstrap.Toast(toastLiveExample);
				}
				else
				{
					var toastLiveUnluck = document.getElementById('liveToastUnLucky');
					toast = new bootstrap.Toast(toastLiveUnluck);
				}
				toast.show();
			}
		});
	});
</script>
